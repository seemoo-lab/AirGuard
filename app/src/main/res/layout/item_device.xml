<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable name="deviceBeaconCount" type="String" />
        <variable name="isClickable" type="Boolean" />
        <variable name="baseDevice" type="de.seemoo.at_tracking_detection.database.models.device.BaseDevice" />
        <import type="android.view.View" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/device_item_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        android:clickable="@{isClickable}"
        android:transitionName="@{baseDevice.address}">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/imageFindMy"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="@string/device_icon"
                android:src="@{baseDevice.getDrawable}"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="?attr/colorPrimary"
                tools:src="@drawable/ic_baseline_device_unknown_24" />

            <TextView
                android:id="@+id/device_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:text="@{baseDevice.deviceNameWithID}"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@{baseDevice.ignore ? @color/md_theme_outline : @color/md_theme_onSurface}"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintStart_toEndOf="@id/imageFindMy"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/status_icons_barrier"
                tools:text="AirTag #1234" />

            <TextView
                android:id="@+id/lbl_first_discovery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/device_item_first_discovery"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                app:layout_constraintStart_toStartOf="@id/device_name"
                app:layout_constraintTop_toBottomOf="@id/device_name" />

            <TextView
                android:id="@+id/val_first_discovery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@{baseDevice.formattedDiscoveryDate}"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginStart="4dp"
                app:layout_constraintStart_toEndOf="@id/lbl_first_discovery"
                app:layout_constraintBaseline_toBaselineOf="@id/lbl_first_discovery"
                tools:text="10.10.2023" />

            <TextView
                android:id="@+id/lbl_last_seen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/device_item_last_seen"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                app:layout_constraintStart_toStartOf="@id/device_name"
                app:layout_constraintTop_toBottomOf="@id/lbl_first_discovery" />

            <TextView
                android:id="@+id/val_last_seen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@{baseDevice.formattedLastSeenDate}"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginStart="4dp"
                app:layout_constraintStart_toEndOf="@id/lbl_last_seen"
                app:layout_constraintBaseline_toBaselineOf="@id/lbl_last_seen"
                tools:text="10.10.2023" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/colorSecondaryContainer"
                app:cardCornerRadius="8dp"
                app:contentPaddingLeft="8dp"
                app:contentPaddingRight="8dp"
                app:contentPaddingTop="2dp"
                app:contentPaddingBottom="2dp"
                app:strokeWidth="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/device_name">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{@string/times_seen + `: ` + deviceBeaconCount}"
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:textColor="?attr/colorOnSecondaryContainer"
                    tools:text="Seen: 8" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/status_icons_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/star_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@string/device_icon"
                    android:visibility="@{baseDevice.hearted ? View.VISIBLE : View.GONE}"
                    app:srcCompat="@drawable/ic_star_filled"
                    app:tint="@color/star_yellow"
                    android:layout_marginEnd="4dp"/>

                <ImageView
                    android:id="@+id/ignored_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@string/alert_sent_icon"
                    android:visibility="@{baseDevice.ignore ? View.VISIBLE : View.GONE}"
                    app:srcCompat="@drawable/ic_baseline_alarm_off_24"
                    app:tint="?attr/colorOutline"
                    android:layout_marginEnd="4dp"/>

                <ImageView
                    android:id="@+id/alert_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@string/alert_sent_icon"
                    android:visibility="@{baseDevice.notificationSent ? View.VISIBLE : View.GONE}"
                    app:srcCompat="@android:drawable/ic_dialog_alert"
                    app:tint="?attr/colorError" />
            </LinearLayout>

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/status_icons_barrier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="start"
                app:constraint_referenced_ids="status_icons_layout" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>