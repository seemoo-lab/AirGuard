<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View" />
        <variable name="clickable" type="java.lang.Boolean" />
        <variable name="checkable" type="java.lang.Boolean" />
        <variable name="checked" type="java.lang.Boolean" />
        <variable name="drawable" type="android.graphics.drawable.Drawable" />
        <variable name="imageDescription" type="String" />
        <variable name="title" type="String" />
        <variable name="subtitle" type="String" />

        <variable name="isLoading" type="java.lang.Boolean" />
        <variable name="isError" type="java.lang.Boolean" />

        <variable name="vm" type="de.seemoo.at_tracking_detection.ui.tracking.TrackingViewModel" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"

        app:cardBackgroundColor="@color/md_theme_surfaceContainerLow"

        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/md_theme_surfaceVariant"
        app:strokeWidth="0dp"
        app:checkedIcon="@null"
        android:clickable="@{clickable}"
        android:checked="@{checked}"
        android:checkable="@{checkable}"
        android:stateListAnimator="@null">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:minHeight="72dp">

            <ImageView
                android:id="@+id/tracking_tile_image"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@{imageDescription}"
                android:src="@{drawable}"
                app:tint="@color/md_theme_primary"
                tools:src="@drawable/ic_baseline_play_circle_outline_24" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tracking_tile_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{title}"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="@color/md_theme_onSurface"
                    tools:text="Play Sound" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{subtitle}"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:visibility="@{subtitle != null &amp;&amp; !subtitle.isEmpty() ? View.VISIBLE : View.GONE}"
                    tools:text="Sound is playing..." />
            </LinearLayout>

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <com.github.ybq.android.spinkit.SpinKitView
                    android:id="@+id/tracking_loading_indicator"
                    style="@style/SpinKitView.Wave"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:indeterminate="true"
                    android:visibility="@{isLoading ? View.VISIBLE : View.GONE}"
                    app:SpinKit_Color="@color/md_theme_primary" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:visibility="@{isError ? View.VISIBLE : View.GONE}"
                    app:srcCompat="@drawable/ic_baseline_error_outline_24"
                    app:tint="@color/md_theme_error"
                    android:contentDescription="@string/error_connection" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:visibility="@{checked ? View.VISIBLE : View.GONE}"
                    app:srcCompat="@drawable/ic_check_circle"
                    app:tint="@color/md_theme_primary"
                    tools:visibility="visible"
                    android:contentDescription="@string/active" />
            </FrameLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>