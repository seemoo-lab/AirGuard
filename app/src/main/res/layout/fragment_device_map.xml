<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:bind="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="vm"
            type="de.seemoo.at_tracking_detection.ui.dashboard.DeviceMapViewModel" />
        <import type="android.view.View" />
    </data>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.devices.DeviceMapFragment">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/mapContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="@{vm.hideMapShowNoDevicesFoundInstead || vm.hideMapShowNoInternetInstead ? View.GONE : View.VISIBLE, default=visible}">

            <include
                android:id="@+id/include_beacon_map"
                layout="@layout/include_map"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                bind:loading="@{vm.isMapLoading}" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/legendFab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:contentDescription="@string/marker_legend"
            app:srcCompat="@drawable/ic_baseline_info_24"
            app:tint="?attr/colorOnPrimaryContainer"
            app:backgroundTint="?attr/colorPrimaryContainer"
            android:visibility="@{vm.hideMapShowNoDevicesFoundInstead || vm.hideMapShowNoInternetInstead ? View.GONE : View.VISIBLE, default=visible}"
            />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/legendContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_margin="16dp"
            android:visibility="invisible"
            app:cardBackgroundColor="@color/md_theme_surfaceContainer"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/legendHeaderBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    bind:layout_constraintTop_toTopOf="parent"
                    bind:layout_constraintStart_toStartOf="parent"
                    bind:layout_constraintEnd_toEndOf="parent">

                    <TextView
                        android:id="@+id/legendHeaderTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/marker_legend"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"
                        bind:layout_constraintStart_toStartOf="parent"
                        bind:layout_constraintEnd_toStartOf="@id/legendCollapseButton"
                        bind:layout_constraintTop_toTopOf="parent"
                        bind:layout_constraintBottom_toBottomOf="parent" />

                    <ImageButton
                        android:id="@+id/legendCollapseButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/close"
                        android:src="@drawable/ic_baseline_close_24"
                        app:tint="?attr/colorOnSurfaceVariant"
                        bind:layout_constraintTop_toTopOf="parent"
                        bind:layout_constraintEnd_toEndOf="parent"
                        bind:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/legendContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp"
                    bind:layout_constraintTop_toBottomOf="@id/legendHeaderBar"
                    bind:layout_constraintStart_toStartOf="parent"
                    bind:layout_constraintEnd_toEndOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/legendRowMarker"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        bind:layout_constraintTop_toTopOf="parent"
                        bind:layout_constraintStart_toStartOf="parent"
                        bind:layout_constraintEnd_toEndOf="parent">

                        <ImageView
                            android:id="@+id/legendMarkerIcon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_baseline_location_on_45_black"
                            app:tint="?attr/colorPrimary"
                            android:contentDescription="@null"
                            bind:layout_constraintStart_toStartOf="parent"
                            bind:layout_constraintTop_toTopOf="parent"
                            bind:layout_constraintBottom_toBottomOf="parent" />

                        <TextView
                            android:id="@+id/legendMarkerText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/device_marker"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:gravity="center_vertical"
                            android:layout_marginStart="16dp"
                            bind:layout_constraintStart_toEndOf="@id/legendMarkerIcon"
                            bind:layout_constraintEnd_toEndOf="parent"
                            bind:layout_constraintTop_toTopOf="@id/legendMarkerIcon"
                            bind:layout_constraintBottom_toBottomOf="@id/legendMarkerIcon" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/legendRowCircle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        bind:layout_constraintTop_toBottomOf="@id/legendRowMarker"
                        bind:layout_constraintStart_toStartOf="parent"
                        bind:layout_constraintEnd_toEndOf="parent">

                        <ImageView
                            android:id="@+id/legendCircleIcon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_legend_circle"
                            app:tint="?attr/colorPrimary"
                            android:contentDescription="@null"
                            bind:layout_constraintStart_toStartOf="parent"
                            bind:layout_constraintTop_toTopOf="parent"
                            bind:layout_constraintBottom_toBottomOf="parent" />

                        <TextView
                            android:id="@+id/legendCircleText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/location_radius_circle"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:gravity="center_vertical"
                            android:layout_marginStart="16dp"
                            bind:layout_constraintStart_toEndOf="@id/legendCircleIcon"
                            bind:layout_constraintEnd_toEndOf="parent"
                            bind:layout_constraintTop_toTopOf="@id/legendCircleIcon"
                            bind:layout_constraintBottom_toBottomOf="@id/legendCircleIcon" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:id="@+id/legendDivider"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp"
                        android:background="?attr/colorOutline"
                        android:alpha="0.2"
                        bind:layout_constraintTop_toBottomOf="@id/legendRowCircle"
                        bind:layout_constraintStart_toStartOf="parent"
                        bind:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/legendFooterText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginTop="12dp"
                        bind:layout_constraintTop_toBottomOf="@id/legendDivider"
                        bind:layout_constraintStart_toStartOf="parent"
                        bind:layout_constraintEnd_toEndOf="parent"
                        tools:text="This map shows locations"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/noDevicesFoundConstraintLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="@{vm.hideMapShowNoDevicesFoundInstead ? View.VISIBLE : View.GONE, default=gone}">

            <include
                android:id="@+id/include_map_empty_explanation"
                layout="@layout/include_empty_explanation"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                bind:drawable="@{@drawable/ic_walk_in_the_city}"
                bind:text="@{@string/map_empty_text}" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/noInternetConstraintLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="@{vm.hideMapShowNoInternetInstead ? View.VISIBLE : View.GONE, default=gone}"
            android:paddingStart="32dp"
            android:paddingEnd="32dp">

            <TextView
                android:id="@+id/noInternetTextView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/export_trackers_no_internet"
                android:gravity="center"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </FrameLayout>
</layout>